    {
      "cell_type": "code",
      "source": [
        "a = int(input(\"Enter the first number: \"))\n",
        "b = int(input(\"Enter the second number: \"))\n",
        "c = int(input(\"Enter the third number: \"))\n",
        "if a >= b and a >= c:\n",
        "  print(\"Largest number is:\", a)\n",
        "elif b >= a and b >= c:\n",
        "  print(\"Largest number is:\", b)\n",
        "else:\n",
        "  print(\"Largest number is:\", c)"
