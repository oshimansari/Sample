      "source": [
        "<a href=\"https://colab.research.google.com/github/oshimansari/Sample/blob/main/pyt.vowels\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
