    },
    {
      "cell_type": "code",
      "source": [
        "# program to count vowels in a string"
      ],
      "metadata": {
        "id": "kVJzWadfSkj6"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "execution_count": 1,
      "metadata": {
        "id": "mIRuAj6MO8RO",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "1f9de1a5-b470-473c-e6e0-9e4e90076e5c"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Enter a string: OSHIM\n"
          ]
        }
      ],
      "source": [
        "text = input(\"Enter a string: \")"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "count = 0"
      ],
      "metadata": {
        "id": "kS1o4gptO-uS"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "Vowels = \"aeiouAEIOU\""
      ],
      "metadata": {
        "id": "egwIhF-7PrvA"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "for char in text:\n",
        "  if char in Vowels:\n",
        "    count += 1"
      ],
      "metadata": {
        "id": "vzQ4GcfHRN9a"
      },
      "execution_count": 8,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"Number of Vowels:\", count)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "EMIB0ijrULaG",
        "outputId": "e9599ac9-0c31-4574-a5a3-1e7c73cbce5e"
      },
